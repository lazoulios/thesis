@article{lykourisCompetitiveCachingMachine2021,
  title = {Competitive {{Caching}} with {{Machine Learned Advice}}},
  author = {Lykouris, Thodoris and Vassilvitskii, Sergei},
  date = {2021-07-14},
  journaltitle = {J. ACM},
  journal = {Journal of the ACM},
  volume = {68},
