@misc{bernsteinDistancepreservingGraphContractions2019,
  title = {Distance-Preserving Graph Contractions},
  author = {Bernstein, Aaron and D{\"a}ubel, Karl and Disser, Yann and Klimm, Max and M{\"u}tze, Torsten and Smolny, Frieder},
  year = 2019,
  month = feb,
  number = {arXiv:1705.04544},
  eprint = {1705.04544},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.1705.04544},
  urldate = {2025-12-18},
  abstract = {Compression and sparsification algorithms are frequently applied in a preprocessing step before analyzing or optimizing large networks/graphs. In this paper we propose and study a new framework contracting edges of a graph (merging vertices into super-vertices) with the goal of preserving pairwise distances as accurately as possible. Formally, given an edge-weighted graph, the contraction should guarantee that for any two vertices at distance \$d\$, the corresponding super-vertices remain at distance at least \$\textbackslash varphi(d)\$ in the contracted graph, where \$\textbackslash varphi\$ is a tolerance function bounding the permitted distance distortion. We present a comprehensive picture of the algorithmic complexity of the contraction problem for affine tolerance functions \$\textbackslash varphi(x)=x/{$\alpha$}-{$\beta\$$}, where \${$\alpha\backslash$}geq 1\$ and \${$\beta\backslash$}geq 0\$ are arbitrary real-valued parameters. Specifically, we present polynomial-time algorithms for trees as well as hardness and inapproximability results for different graph classes, precisely separating easy and hard cases. Further we analyze the asymptotic behavior of contractions, and find efficient algorithms to compute (non-optimal) contractions despite our hardness results.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Data Structures and Algorithms},
  file = {C\:\\Users\\lazgi\\Zotero\\storage\\YNF74ZYH\\Bernstein et al. - 2019 - Distance-preserving graph contractions.pdf;C\:\\Users\\lazgi\\Zotero\\storage\\JLBXTDVG\\1705.html}
}

@misc{chenFasterFundamentalGraph2022,
  title = {Faster {{Fundamental Graph Algorithms}} via {{Learned Predictions}}},
  author = {Chen, Justin Y. and Silwal, Sandeep and Vakilian, Ali and Zhang, Fred},
  year = 2022,
  month = apr,
  number = {arXiv:2204.12055},
  eprint = {2204.12055},
  primaryclass = {cs},
  publisher = {arXiv},
  doi = {10.48550/arXiv.2204.12055},
  urldate = {2025-12-18},
  abstract = {We consider the question of speeding up classic graph algorithms with machine-learned predictions. In this model, algorithms are furnished with extra advice learned from past or similar instances. Given the additional information, we aim to improve upon the traditional worst-case run-time guarantees. Our contributions are the following: (i) We give a faster algorithm for minimum-weight bipartite matching via learned duals, improving the recent result by Dinitz, Im, Lavastida, Moseley and Vassilvitskii (NeurIPS, 2021); (ii) We extend the learned dual approach to the single-source shortest path problem (with negative edge lengths), achieving an almost linear runtime given sufficiently accurate predictions which improves upon the classic fastest algorithm due to Goldberg (SIAM J. Comput., 1995); (iii) We provide a general reduction-based framework for learning-based graph algorithms, leading to new algorithms for degree-constrained subgraph and minimum-cost \$0\$-\$1\$ flow, based on reductions to bipartite matching and the shortest path problem. Finally, we give a set of general learnability theorems, showing that the predictions required by our algorithms can be efficiently learned in a PAC fashion.},
  archiveprefix = {arXiv},
  keywords = {Computer Science - Data Structures and Algorithms},
  file = {C\:\\Users\\lazgi\\Zotero\\storage\\P9UYEED4\\Chen et al. - 2022 - Faster Fundamental Graph Algorithms via Learned Predictions.pdf;C\:\\Users\\lazgi\\Zotero\\storage\\3JTLF4BY\\2204.html}
}

